<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF121212"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SkinTracker"
            android:textColor="#99FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_item_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 items"
            android:textColor="#99FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Portfolio value -->
    <TextView
        android:id="@+id/widget_total_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="--"
        android:textColor="#FFFFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:maxLines="1" />

    <!-- 24h change row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_change_arrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\u2197"
            android:textColor="#FF4CAF50"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_change_pct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="--"
            android:textColor="#FF4CAF50"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_change_abs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="--"
            android:textColor="#FF4CAF50"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Last updated -->
    <TextView
        android:id="@+id/widget_last_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Never"
        android:textColor="#66FFFFFF"
        android:textSize="10sp" />

</LinearLayout>
