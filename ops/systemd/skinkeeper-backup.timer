[Unit]
Description=Daily SkinKeeper Postgres backup

[Timer]
# 03:00 UTC every day. Persistent=true so a missed trigger (VPS was
# off) fires as soon as the system is back up.
OnCalendar=*-*-* 03:00:00 UTC
Persistent=true
RandomizedDelaySec=5m
Unit=skinkeeper-backup.service

[Install]
WantedBy=timers.target
