PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skintracker

# ─── Sentry error tracking ───────────────────────────────────────────────────
# Get the DSN from Sentry → Project → Settings → Client Keys (DSN).
# Leave blank in local dev — Sentry is silently disabled when DSN is unset.
# In production, absence of DSN logs a console.error at boot.
SENTRY_DSN=
# Set by CI to the git commit SHA so Sentry can link errors to releases.
# CI: SENTRY_RELEASE=$(git rev-parse HEAD)
# Falls back to 'unknown' if unset.
SENTRY_RELEASE=
JWT_SECRET=change-me-to-a-random-secret
STEAM_API_KEY=your-steam-api-key-from-steamcommunity.com/dev/apikey
CSFLOAT_API_KEY=your-csfloat-api-key
DMARKET_PUBLIC_KEY=your-dmarket-public-key
DMARKET_SECRET_KEY=your-dmarket-secret-key-hex
# Comma-separated Chrome Web Store extension IDs allowed to call the API
# from a browser context (CORS allowlist, HIGH-5). Production extension ID
# only — never include unpublished dev IDs in prod.
CHROME_EXTENSION_IDS=

# ─── Google Play Developer API (Android IAP verification) ───────────────
# Service account JSON, base64-encoded.
# Get it from: Google Cloud Console → IAM → Service Accounts → Create
# → grant "Pub/Sub Publisher" + bind to Play Console (Settings → API access).
# Then base64 the downloaded .json:
#   base64 -i service-account.json | tr -d '\n'
# Raw JSON also accepted (auto-detected if the value starts with "{").
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
# Android package name registered in Play Console (must match service account binding).
GOOGLE_PLAY_PACKAGE_NAME=com.skinkeeper.app

# ─── Google Play Real-Time Developer Notifications (RTDN) ────────────────
# Random hex token used to harden the Pub/Sub push endpoint:
#   POST /api/purchases/google-rtdn-<TOKEN>
# Pub/Sub doesn't sign Bearer tokens, so a hard-to-guess path is the MVP guard.
# Generate with:  openssl rand -hex 32
# In Play Console → Settings → Monetization → RTDN, point the push subscription
# at https://api.skinkeeper.store/api/purchases/google-rtdn-<TOKEN>.
# If unset in production, the route mounts at /google-rtdn-dev — boot logs a
# warning, but anyone can hit it. SET THIS in any deployed env.
GOOGLE_RTDN_PATH_TOKEN=

# ─── DEVELOPMENT ONLY — never set in production ─────────────────────────
# Set to "1" to skip Apple/Google receipt verification and trust the client.
# Used for local emulator/sideload testing where there's no real receipt.
# In production, leaving this unset combined with the API env vars above is
# the correct config — verifyGoogleReceipt will fail closed.
ALLOW_UNVERIFIED_RECEIPTS=
