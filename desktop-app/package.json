{
  "name": "skinkeeper-desktop",
  "version": "1.0.0",
  "description": "SkinKeeper Desktop — CS2 inventory management & trading toolkit",
  "main": "dist/main/main.js",
  "author": "SkinKeeper",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "cd ../web-app && next dev -p 3001",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "cd ../web-app && next build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "electron dist/main/main.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "steam-user": "^5.2.0",
    "steam-session": "^1.8.0",
    "steam-totp": "^2.1.2",
    "steam-tradeoffer-manager": "^2.12.5",
    "steamcommunity": "^3.48.5",
    "globaloffensive": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "concurrently": "^9.1.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.0"
  }
}
